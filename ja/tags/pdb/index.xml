&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;PdbFile: D:&lt;span class=&#34;se&#34;&gt;\s&lt;/span&gt;tock_UAT&lt;span class=&#34;se&#34;&gt;\y&lt;/span&gt;kcz_securities_trading_client&lt;span class=&#34;se&#34;&gt;\S&lt;/span&gt;ec_Trade&lt;span class=&#34;se&#34;&gt;\Y&lt;/span&gt;inTrade.Main&lt;span class=&#34;se&#34;&gt;\o&lt;/span&gt;bj&lt;span class=&#34;se&#34;&gt;\R&lt;/span&gt;elease&lt;span class=&#34;se&#34;&gt;\Y&lt;/span&gt;inTrade.Main.pdb
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;Debug info: &lt;span class=&#34;m&#34;&gt;16&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;(&lt;/span&gt; Unknown &lt;span class=&#34;o&#34;&gt;)&lt;/span&gt;
