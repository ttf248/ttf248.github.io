&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;Debug info: &lt;span class=&#34;m&#34;&gt;2&lt;/span&gt; &lt;span class=&#34;o&#34;&gt;(&lt;/span&gt; CodeView &lt;span class=&#34;o&#34;&gt;)&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;TimeStamp: f86b0a4f  Characteristics: &lt;span class=&#34;m&#34;&gt;0&lt;/span&gt;  MajorVer: &lt;span class=&#34;m&#34;&gt;0&lt;/span&gt;  MinorVer: &lt;span class=&#34;m&#34;&gt;0&lt;/span&gt;
